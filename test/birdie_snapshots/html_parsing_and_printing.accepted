---
version: 2.0.2
title: html parsing and printing
file: ./test/mellie/parse_test.gleam
test_name: parse_full_html_test
---
<html>
  <head>
  </head>
  <body>
    <h2>Welcome!</h2>
    <p>This is some content in Markdown that can be rendered to your site</p>
    <p>Here&#39;s a code block and some other
      <em>fancy</em>
      formatting</p>
    <my-custom-tag data="hello world">
      <blockquote>
        <h2>Nested Heading</h2>
        <pre>
          <code class="language-gleam">code |&gt; print_me |&gt; echo
          </code>
        </pre>
      </blockquote>
    </my-custom-tag>
    <script type="module" src="my/script/src"></script>
    <script>
  console.log('some stuff')
  console.log('other stuff')
</script>
    <style>
  .some-class {
    background-color: green;
  }
</style>
  </body>
</html>
